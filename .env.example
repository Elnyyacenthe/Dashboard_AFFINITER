# Database — Supabase PARTAGÉE avec le projet yamo principal
DATABASE_URL="postgresql://postgres:password@localhost:5432/yamo?schema=public"

# Auth.js (NextAuth v5) — UTILISER LE MÊME SECRET que yamo principal
# pour que les sessions soient partagées entre yamo.cm et dashboard.yamo.cm
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST=true

# UploadThing — mêmes clés que yamo principal
UPLOADTHING_TOKEN="your-uploadthing-token"
UPLOADTHING_SECRET="your-uploadthing-secret"

# K-Pay (paiements MoMo + Orange Money) — mêmes clés que yamo principal
KPAY_BASE_URL="https://admin.kpay.site"
KPAY_API_KEY=""
KPAY_SECRET_KEY=""
KPAY_WEBHOOK_SECRET=""              # ⚠️ OBLIGATOIRE EN PROD
KPAY_CALLBACK_URL="http://localhost:3001/api/webhooks/kpay"

# Upstash Redis — mêmes credentials que yamo principal (rate limit partagé)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Yamo"

# URLs externes vers le projet yamo principal (qui contient le site public + l'admin)
NEXT_PUBLIC_YAMO_URL="https://yamo.cm"
# Si vide → utilise NEXT_PUBLIC_YAMO_URL + "/admin"
NEXT_PUBLIC_YAMO_ADMIN_URL=""
