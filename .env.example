# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/yamo?schema=public"

# Auth.js (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# UploadThing
UPLOADTHING_TOKEN="your-uploadthing-token"
UPLOADTHING_SECRET="your-uploadthing-secret"

# K-Pay (paiements MoMo + Orange Money)
# Récupère ces clés sur https://admin.kpay.site
KPAY_BASE_URL="https://admin.kpay.site"
KPAY_API_KEY=""              # format kpay_test_xxx (sandbox) ou kpay_live_xxx
KPAY_SECRET_KEY=""
KPAY_WEBHOOK_SECRET=""       # Optionnel mais recommandé (HMAC du body)
KPAY_CALLBACK_URL="http://localhost:3000/api/webhooks/kpay"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Yamo"

# Admin (utilisé pour le seed)
ADMIN_EMAIL="admin@yamo.cm"
ADMIN_PASSWORD="ChangeMe123!"
